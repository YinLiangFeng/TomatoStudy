<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/taskHeaderLayout"
        android:layout_width="match_parent"
        android:layout_height="138dp"
        android:background="@drawable/bg_task_header"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/taskTitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_task"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/studyModeText"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_study_mode_pill"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="@string/study_mode_entry"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/headerStatisticsText"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="@string/header_statistics_icon"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/headerTimerText"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="14dp"
                android:gravity="center"
                android:text="@string/header_timer_icon"
                android:textColor="@color/white"
                android:textSize="25sp" />

            <TextView
                android:id="@+id/headerAddText"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="14dp"
                android:gravity="center"
                android:text="@string/header_add_icon"
                android:textColor="@color/white"
                android:textSize="36sp" />

            <TextView
                android:id="@+id/headerMoreText"
                android:layout_width="32dp"
                android:layout_height="42dp"
                android:layout_marginStart="10dp"
                android:gravity="center"
                android:text="@string/header_more_icon"
                android:textColor="@color/white"
                android:textSize="28sp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/taskRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="18dp" />

    <TextView
        android:id="@+id/taskEmptyText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/task_empty_tip"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:visibility="gone" />
</LinearLayout>
